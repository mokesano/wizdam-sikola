# Aplikasi
APP_NAME="Wizdam AI-Sikola"
APP_ENV=development
APP_DEBUG=true
APP_URL=https://www.sangia.org
BASE_PATH=/var/www/wizdam-sikola
TWIG_CACHE=false

# CORS - origin yang diizinkan untuk REST API (dipisahkan koma)
# Development: http://localhost:3000  |  Production: https://www.sangia.org
APP_CORS_ORIGINS=http://localhost:3000,https://www.sangia.org

# ── React Frontend (.env di root project) ────────────────────────────────────
# Copy baris berikut ke file .env di root project (bukan file ini)
# REACT_APP_API_URL=http://localhost:8000/api/v1        # development
# REACT_APP_API_URL=https://www.sangia.org/api/v1       # production

# Database
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=wizdam_sikola
DB_USERNAME=root
DB_PASSWORD=your_secure_password
DB_CHARSET=utf8mb4

# Redis (untuk queue - opsional)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# ORCID OAuth2
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=https://www.sangia.org/auth/orcid-callback
ORCID_SANDBOX=true

# Sangia AI Engine
SANGIA_API_URL=https://api.sangia.org
SANGIA_API_VERSION=v1
SANGIA_API_KEY=
API_TIMEOUT=30
API_ASYNC_ENABLED=true

# Scopus API
SCOPUS_API_KEY=

# WizdamCrawler
CRAWLER_RECEIVER_TOKEN=

# Security
SESSION_LIFETIME=120
ENCRYPTION_KEY=generate_32_character_random_key_here

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx

# GeoIP
GEOIP_DB_PATH=/path/to/GeoIP.dat

# Queue Settings
QUEUE_DRIVER=database
QUEUE_CONNECTION=default
