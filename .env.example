# Aplikasi
APP_NAME="Wizdam Sicola"
APP_ENV=development
APP_DEBUG=true
APP_URL=https://www.sangia.org
BASE_PATH=/var/www/wizdam-sicola
TWIG_CACHE=false

# CORS - origin yang diizinkan untuk REST API (dipisahkan koma)
# Development: http://localhost:3000  |  Production: https://www.sangia.org
APP_CORS_ORIGINS=http://localhost:3000,https://www.sangia.org

# ── React/Vite Frontend ──────────────────────────────────────────────────────
# Variabel VITE_ dibaca oleh Vite saat build; REACT_APP_ didukung sebagai alias.
# Development
VITE_API_URL=http://localhost:8000/api/v1
REACT_APP_API_URL=http://localhost:8000/api/v1
# Production (ganti sesuai kebutuhan)
# VITE_API_URL=https://www.sangia.org/api/v1
# REACT_APP_API_URL=https://www.sangia.org/api/v1

# Database
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=wizdam_sicola
DB_USERNAME=root
DB_PASSWORD=your_secure_password
DB_CHARSET=utf8mb4

# Redis (untuk queue - opsional)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# ORCID OAuth2
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=https://www.sangia.org/auth/orcid-callback
ORCID_SANDBOX=true

# Sangia AI Engine
SANGIA_API_URL=https://api.sangia.org
SANGIA_API_VERSION=v1
# SANGIA_API_KEY: untuk kompatibilitas mundur; kunci per-user sekarang di-generate via ApiKeyManager
SANGIA_API_KEY=
# SANGIA_SERVICE_KEY: kunci layanan level-admin (untuk endpoint revoke, dll.)
SANGIA_SERVICE_KEY=
API_TIMEOUT=30
API_ASYNC_ENABLED=true

# Shared Secret — HARUS sama dengan nilai di wizdam-apis
# Dipakai untuk menghitung HMAC pada format kunci: wz_{user_id}_{timestamp}_{hmac16}
# Generate: php -r "echo bin2hex(random_bytes(32));"
WIZDAM_SHARED_SECRET=

# Scopus API
SCOPUS_API_KEY=

# WizdamCrawler
CRAWLER_RECEIVER_TOKEN=

# Security
SESSION_LIFETIME=120
ENCRYPTION_KEY=generate_32_character_random_key_here

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx

# GeoIP
GEOIP_DB_PATH=/path/to/GeoIP.dat

# Queue Settings
QUEUE_DRIVER=database
QUEUE_CONNECTION=default
