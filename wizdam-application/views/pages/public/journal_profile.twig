{% extends 'layouts/base.twig' %}

{% block content %}
<div class="max-w-5xl mx-auto space-y-6">

    <!-- Header Jurnal -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
        <div class="flex flex-col md:flex-row gap-6 items-start">
            <div class="flex-1">
                <h1 class="text-2xl font-bold text-slate-900">{{ journal.title }}</h1>
                <p class="text-slate-500 text-sm mt-1">
                    ISSN: <span class="font-mono">{{ journal.issn }}</span>
                    {% if journal.e_issn %} · e-ISSN: <span class="font-mono">{{ journal.e_issn }}</span>{% endif %}
                </p>
                {% if journal.publisher %}
                <p class="text-slate-400 text-xs mt-1">Penerbit: {{ journal.publisher }}</p>
                {% endif %}

                <!-- Badge Indeksasi -->
                <div class="flex flex-wrap gap-2 mt-3">
                    {% if indexing.sinta and indexing.sinta.indexed %}
                    <span class="badge badge-blue">SINTA {{ indexing.sinta.rank ?? '' }}</span>
                    {% endif %}
                    {% if indexing.scopus and indexing.scopus.indexed %}
                    <span class="badge badge-indigo">Scopus</span>
                    {% if indexing.scopus.sjr %}
                    <span class="badge badge-slate text-xs">SJR {{ indexing.scopus.sjr }}</span>
                    {% endif %}
                    {% endif %}
                    {% if indexing.wos and indexing.wos.indexed %}
                    <span class="badge badge-emerald">WoS / ESCI</span>
                    {% endif %}
                    {% if journal.is_predatory %}
                    <span class="badge badge-red">Potensial Predatory</span>
                    {% endif %}
                </div>
            </div>
            <div class="flex-shrink-0">
                {% include 'components/impact_score_badge.twig' with {score: score, size: 'lg'} %}
            </div>
        </div>

        <!-- Tombol cek indeksasi real-time -->
        {% if not liveIndexing %}
        <div class="mt-4 pt-4 border-t border-slate-100">
            <a href="{{ app.base_url }}/journal/{{ journal.issn }}?check_indexing=1"
               class="btn btn-ghost text-xs">
                Cek Status Indeksasi Real-Time →
            </a>
        </div>
        {% endif %}
    </div>

    {% if liveIndexing %}
    <!-- Live Indexing Result -->
    <div class="bg-indigo-50 border border-indigo-200 rounded-2xl p-5">
        <h2 class="text-sm font-semibold text-indigo-700 mb-3">Hasil Cek Indeksasi Real-Time</h2>
        <div class="grid grid-cols-3 gap-4 text-center text-sm">
            <div class="bg-white rounded-xl p-3 shadow-sm">
                <div class="font-bold text-lg {% if liveIndexing.scopus.indexed %}text-emerald-600{% else %}text-slate-400{% endif %}">
                    {{ liveIndexing.scopus.indexed ? '✓' : '✗' }}
                </div>
                <div class="text-slate-500 text-xs">Scopus</div>
                {% if liveIndexing.scopus.sjr %}
                <div class="text-xs text-slate-400">SJR {{ liveIndexing.scopus.sjr }}</div>
                {% endif %}
            </div>
            <div class="bg-white rounded-xl p-3 shadow-sm">
                <div class="font-bold text-lg {% if liveIndexing.sinta.indexed %}text-emerald-600{% else %}text-slate-400{% endif %}">
                    {{ liveIndexing.sinta.indexed ? '✓' : '✗' }}
                </div>
                <div class="text-slate-500 text-xs">SINTA</div>
                {% if liveIndexing.sinta.rank is defined %}
                <div class="text-xs text-slate-400">Peringkat {{ liveIndexing.sinta.rank }}</div>
                {% endif %}
            </div>
            <div class="bg-white rounded-xl p-3 shadow-sm">
                <div class="font-bold text-lg {% if liveIndexing.wos.indexed %}text-emerald-600{% else %}text-slate-400{% endif %}">
                    {{ liveIndexing.wos.indexed ? '✓' : '✗' }}
                </div>
                <div class="text-slate-500 text-xs">WoS</div>
            </div>
        </div>
    </div>
    {% endif %}

    <!-- Artikel Terbaru -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-5">
        <h2 class="text-base font-semibold text-slate-700 mb-4">Artikel Terbaru</h2>
        {% if articles %}
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-100 text-xs text-slate-400 uppercase">
                        <th class="py-2 text-left">Judul</th>
                        <th class="py-2 text-right">Tahun</th>
                        <th class="py-2 text-right">Sitasi</th>
                        <th class="py-2 text-right">Skor</th>
                    </tr>
                </thead>
                <tbody>
                {% for a in articles %}
                <tr class="border-b border-slate-50 hover:bg-slate-50">
                    <td class="py-2.5 pr-4 font-medium text-slate-800 max-w-sm truncate">
                        {% if a.doi %}
                        <a href="https://doi.org/{{ a.doi }}" target="_blank" rel="noopener" class="hover:text-indigo-600">{{ a.title }}</a>
                        {% else %}
                        {{ a.title }}
                        {% endif %}
                    </td>
                    <td class="py-2.5 text-right text-slate-500">{{ a.year }}</td>
                    <td class="py-2.5 text-right font-medium text-slate-700">{{ a.citations }}</td>
                    <td class="py-2.5 text-right">
                        <span class="badge badge-indigo">{{ a.impact_score|round(1) }}</span>
                    </td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
            <p class="text-slate-400 text-sm italic text-center py-6">Belum ada artikel yang tercatat.</p>
        {% endif %}
    </div>

</div>
{% endblock %}
