{% extends 'layouts/base.twig' %}

{% block title %}Image Resizer – Wizdam Tools{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto space-y-6">

    <div>
        <h1 class="text-2xl font-bold text-slate-900">Image Resizer</h1>
        <p class="text-slate-500 text-sm mt-1">Resize gambar JPEG, PNG, WebP, atau GIF langsung di browser. Maksimal 10 MB.</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 space-y-5">

        <!-- Drop Zone -->
        <div id="drop-zone"
             class="border-2 border-dashed border-slate-300 rounded-xl p-10 text-center cursor-pointer
                    hover:border-indigo-400 hover:bg-indigo-50 transition-colors">
            <svg class="w-10 h-10 text-slate-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <p class="text-slate-500 text-sm">Seret gambar ke sini atau <span class="text-indigo-600 font-medium">klik untuk memilih</span></p>
            <input type="file" id="imageInput" accept="image/*" class="hidden">
        </div>

        <!-- Kontrol -->
        <div class="grid grid-cols-3 gap-4">
            <div>
                <label class="block text-xs font-medium text-slate-600 mb-1">Lebar (px)</label>
                <input type="number" id="widthInput" value="800" min="1" max="5000" class="form-input w-full">
            </div>
            <div>
                <label class="block text-xs font-medium text-slate-600 mb-1">Tinggi (px, 0=proporsional)</label>
                <input type="number" id="heightInput" value="0" min="0" max="5000" class="form-input w-full">
            </div>
            <div>
                <label class="block text-xs font-medium text-slate-600 mb-1">Kualitas (%)</label>
                <input type="number" id="qualityInput" value="85" min="10" max="100" class="form-input w-full">
            </div>
        </div>

        <!-- Tombol -->
        <button id="resizeBtn" disabled
                class="btn btn-primary w-full py-2.5 disabled:opacity-50 disabled:cursor-not-allowed">
            Resize Sekarang
        </button>

        <!-- Progress -->
        <div id="progress" class="hidden">
            <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div id="progress-bar" class="h-full bg-indigo-500 animate-pulse w-full"></div>
            </div>
            <p class="text-xs text-slate-400 text-center mt-1">Memproses…</p>
        </div>

        <!-- Hasil -->
        <div id="result" class="hidden bg-slate-50 rounded-xl border border-slate-200 p-4 space-y-3">
            <p class="text-sm font-semibold text-slate-700">Hasil Resize</p>
            <div class="flex gap-4 text-xs text-slate-500">
                <span>Ukuran: <strong id="res-size" class="text-slate-800">–</strong></span>
                <span>Dimensi: <strong id="res-dims" class="text-slate-800">–</strong></span>
            </div>
            <a id="downloadLink" href="#" download class="btn btn-primary text-xs inline-block">
                Unduh Gambar
            </a>
        </div>

        <!-- Error -->
        <div id="error-box" class="hidden p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
const dropZone   = document.getElementById('drop-zone');
const imageInput = document.getElementById('imageInput');
const resizeBtn  = document.getElementById('resizeBtn');
const progress   = document.getElementById('progress');
const result     = document.getElementById('result');
const errorBox   = document.getElementById('error-box');

let selectedFile = null;

dropZone.addEventListener('click', () => imageInput.click());
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('border-indigo-500'); });
dropZone.addEventListener('dragleave',  () => dropZone.classList.remove('border-indigo-500'));
dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('border-indigo-500');
    handleFile(e.dataTransfer.files[0]);
});
imageInput.addEventListener('change', () => handleFile(imageInput.files[0]));

function handleFile(file) {
    if (!file) return;
    selectedFile = file;
    dropZone.querySelector('p').textContent = `✓ ${file.name} (${(file.size / 1024).toFixed(1)} KB)`;
    resizeBtn.disabled = false;
}

resizeBtn.addEventListener('click', async () => {
    if (!selectedFile) return;

    errorBox.classList.add('hidden');
    result.classList.add('hidden');
    progress.classList.remove('hidden');
    resizeBtn.disabled = true;

    const fd = new FormData();
    fd.append('image',   selectedFile);
    fd.append('width',   document.getElementById('widthInput').value);
    fd.append('height',  document.getElementById('heightInput').value);
    fd.append('quality', document.getElementById('qualityInput').value);

    try {
        const res  = await fetch('/tools/image-resizer', { method: 'POST', body: fd });
        const data = await res.json();

        progress.classList.add('hidden');

        if (data.error) {
            errorBox.textContent = data.error;
            errorBox.classList.remove('hidden');
        } else {
            document.getElementById('res-size').textContent = `${data.size_kb} KB`;
            document.getElementById('res-dims').textContent = `${data.width} × ${data.height}`;
            document.getElementById('downloadLink').href = data.url;
            result.classList.remove('hidden');
        }
    } catch (e) {
        progress.classList.add('hidden');
        errorBox.textContent = 'Terjadi kesalahan jaringan.';
        errorBox.classList.remove('hidden');
    } finally {
        resizeBtn.disabled = false;
    }
});
</script>
{% endblock %}
