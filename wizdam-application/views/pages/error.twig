{% extends 'layouts/base.twig' %}

{% block title %}Error {{ code }} – {{ app.name }}{% endblock %}

{% block content %}
<div class="min-h-[60vh] flex flex-col items-center justify-center text-center py-16 px-4">
    <div class="text-8xl font-black text-slate-100 select-none mb-4">{{ code }}</div>
    <h1 class="text-xl font-bold text-slate-700 mb-2">
        {% if code == 404 %}Halaman Tidak Ditemukan
        {% elseif code == 403 %}Akses Ditolak
        {% elseif code == 500 %}Kesalahan Server
        {% else %}Terjadi Kesalahan
        {% endif %}
    </h1>
    <p class="text-slate-500 text-sm max-w-md">{{ message }}</p>
    <a href="/" class="mt-6 btn btn-primary text-sm">← Kembali ke Beranda</a>
</div>
{% endblock %}
