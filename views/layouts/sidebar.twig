<!DOCTYPE html>
<html lang="id" class="h-full">
<head>
    <title>{% block title %}{{ pageTitle ?? app.name }}{% endblock %}</title>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/assets/css/app.css">
    {% block head %}{% endblock %}
</head>
<body class="bg-slate-100 min-h-full font-sans">

    <!-- ── Sidebar Layout ── -->
    <div class="flex min-h-screen">

        <!-- Sidebar -->
        <aside class="sidebar w-64 bg-indigo-900 text-white flex-shrink-0 flex flex-col">
            <!-- Logo -->
            <div class="px-6 py-5 border-b border-indigo-800">
                <a href="/" class="flex items-center gap-2 font-bold text-base">
                    <svg class="w-6 h-6 text-indigo-300" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                    </svg>
                    Wizdam Sicola
                </a>
            </div>

            <!-- Menu -->
            <nav class="flex-1 px-4 py-6 space-y-1 text-sm">
                <a href="/dashboard" class="sidebar-link {% if activeMenu == 'dashboard' %}active{% endif %}">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h18M3 12h18M3 17h18"/></svg>
                    Dashboard Saya
                </a>

                {% if isAdmin ?? false %}
                <div class="pt-4 pb-1 px-2 text-xs font-semibold text-indigo-400 uppercase tracking-wider">Admin</div>
                <a href="/admin" class="sidebar-link {% if activeMenu == 'admin' %}active{% endif %}">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    Analytics Platform
                </a>
                {% endif %}

                <div class="pt-4 pb-1 px-2 text-xs font-semibold text-indigo-400 uppercase tracking-wider">Tools</div>
                <a href="/tools/image-resizer" class="sidebar-link {% if activeMenu == 'image-resizer' %}active{% endif %}">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    Image Resizer
                </a>
                <a href="/tools/pdf-compress" class="sidebar-link {% if activeMenu == 'pdf-compress' %}active{% endif %}">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                    PDF Compressor
                </a>
            </nav>

            <!-- Logout -->
            <div class="px-4 py-4 border-t border-indigo-800">
                <a href="/auth/logout" class="sidebar-link text-indigo-300 hover:text-white hover:bg-indigo-800">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    Keluar
                </a>
            </div>
        </aside>

        <!-- Main Area -->
        <div class="flex-1 flex flex-col min-w-0">
            <!-- Top bar -->
            <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between">
                <h1 class="text-lg font-semibold text-slate-800">{% block page_heading %}{% endblock %}</h1>
                <div class="text-sm text-slate-500">Wizdam Sicola</div>
            </header>

            <!-- Content -->
            <main class="flex-1 p-6">
                {% block content %}{% endblock %}
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/frappe-charts/dist/frappe-charts.min.umd.js"></script>
    <script src="/assets/js/app.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
