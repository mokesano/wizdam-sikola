<!DOCTYPE html>
<html lang="id" class="h-full">
<head>
    <title>{% block title %}{{ pageTitle ?? app.name }}{% endblock %}</title>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{% block description %}Platform pengukuran dampak riset Indonesia berbasis AI.{% endblock %}">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg">

    <!-- Stylesheet utama -->
    <link rel="stylesheet" href="/assets/css/app.css">

    {% block head %}{% endblock %}
</head>
<body class="bg-slate-50 text-slate-800 min-h-full flex flex-col font-sans">

    <!-- ── Navbar ── -->
    <header class="navbar sticky top-0 z-50 bg-white shadow-sm border-b border-slate-200">
        <div class="container mx-auto px-4 flex items-center justify-between h-16">

            <!-- Logo -->
            <a href="/" class="flex items-center gap-2 font-bold text-lg text-indigo-700">
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                </svg>
                Wizdam <span class="text-slate-400 font-normal text-sm ml-1">Sicola</span>
            </a>

            <!-- Nav Links -->
            <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-600">
                <a href="/" class="hover:text-indigo-600 transition-colors">Beranda</a>
                <a href="/journal/0000-0000" class="hover:text-indigo-600 transition-colors">Jurnal</a>
                <a href="/tools/image-resizer" class="hover:text-indigo-600 transition-colors">Tools</a>
            </nav>

            <!-- Auth -->
            <div class="flex items-center gap-3 text-sm">
                {% if currentUser %}
                    <a href="/dashboard" class="text-slate-600 hover:text-indigo-600 transition-colors">Dashboard</a>
                    <a href="/auth/logout" class="btn btn-ghost text-xs">Keluar</a>
                {% else %}
                    <a href="/auth/login" class="btn btn-primary text-xs">Masuk</a>
                {% endif %}
            </div>
        </div>
    </header>

    <!-- ── Konten Utama ── -->
    <main class="flex-1 {% block main_class %}container mx-auto px-4 py-8{% endblock %}">
        {% block content %}{% endblock %}
    </main>

    <!-- ── Footer ── -->
    <footer class="bg-white border-t border-slate-200 py-6 mt-auto">
        <div class="container mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-2 text-xs text-slate-400">
            <span>&copy; {{ "now"|date("Y") }} Wizdam Sicola. Didukung oleh <a href="https://sangia.org" class="text-indigo-400 hover:underline">Sangia</a>.</span>
            <nav class="flex gap-4">
                <a href="/tools/image-resizer" class="hover:text-slate-600">Image Resizer</a>
                <a href="/tools/pdf-compress" class="hover:text-slate-600">PDF Compressor</a>
            </nav>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/frappe-charts/dist/frappe-charts.min.umd.js"></script>
    <script src="/assets/js/app.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
